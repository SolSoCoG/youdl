FROM golang:1.23-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o /bin/controller ./cmd/controller

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=build /bin/controller /usr/local/bin/controller
COPY web/ /app/web/
WORKDIR /app
EXPOSE 8080
CMD ["controller"]
